      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Database Transactions",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"syndock_shop\"}[5m])",
          "legendFormat": "commits/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"syndock_shop\"}[5m])",
          "legendFormat": "rollbacks/s",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
